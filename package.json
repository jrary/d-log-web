{
  "name": "gridge-worker-react-ts-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "build-local": "pnpm run generate-api-dev && tsc -b && vite build",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "dev": "pnpm run generate-api-dev && vite",
    "format": "prettier --write .",
    "generate-api-dev": "openapi-generator-cli generate -i https://worker-api-dev.gridge.co.kr/api-docs -g typescript-axios --skip-validate-spec --additional-properties withSeparateModelsAndApi=true,apiPackage=api,modelPackage=model -a \"Authorization:Basic%20Z3JpZGdlOnAxbk5MelQ0bzJWbndublZYNk9Ldnc=\" -o ./src/apis",
    "generate-api-prod": "openapi-generator-cli generate -i https://worker-api-prod.gridge.co.kr/api-docs -g typescript-axios --skip-validate-spec --additional-properties withSeparateModelsAndApi=true,apiPackage=api,modelPackage=model -a \"Authorization:Basic%20Z3JpZGdlOnAxbk5MelQ0bzJWbndublZYNk9Ldnc=\" -o ./src/apis",
    "generate-api-stage": "openapi-generator-cli generate -i https://worker-api-stage.gridge.co.kr/api-docs -g typescript-axios --skip-validate-spec --additional-properties withSeparateModelsAndApi=true,apiPackage=api,modelPackage=model -a \"Authorization:Basic%20Z3JpZGdlOnAxbk5MelQ0bzJWbndublZYNk9Ldnc=\" -o ./src/apis",
    "lint": "eslint .",
    "preview": "vite preview",
    "stage": "pnpm run generate-api-stage && vite --mode stage",
    "test": "start-server-and-test dev http://localhost:3000 cypress:run"
  },
